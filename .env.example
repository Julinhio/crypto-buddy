# Binance Testnet API credentials (HMAC-SHA256)
# Create them at https://testnet.binance.vision/
# Permissions needed: read account + spot trading
# NEVER commit the real .env file.
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here

# Supabase (OPTIONAL — server-side persistence for the ATH/ATL cache)
# Leave BOTH commented out to run without the cache: the bot still works and
# computes ATH/ATL from the long series each run (a single warning is logged).
# Uncomment and fill them in to enable the cache.
#
# Use the SERVICE ROLE key: this is a backend, the key bypasses RLS and must
# stay server-side only. NEVER expose it client-side, NEVER commit it.
# Find both in the Supabase dashboard → Project Settings → API.
#SUPABASE_URL=https://your-project-ref.supabase.co
#SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
